# ==============================================================================
# SCALECORE - Environment Variables Configuration
# ==============================================================================
# This file documents all environment variables required for the application.
# Copy this file to .env.local and fill in the values for your environment.
#
# IMPORTANT: Never commit .env.local or any file with real secrets to git!
# ==============================================================================


# ==============================================================================
# SUPABASE CONFIGURATION
# ==============================================================================
# Get these values from your Supabase project dashboard:
# https://app.supabase.com/project/YOUR_PROJECT/settings/api

# Public URL for Supabase - used in both client and server
# Found in: Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon (public) key - safe to expose in browser
# Found in: Project Settings > API > anon public key
# Used for: Client-side authentication and public data access
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role key - KEEP SECRET, never expose to client
# Found in: Project Settings > API > service_role secret
# Used for: Server-side operations that bypass RLS (webhooks, background jobs)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key


# ==============================================================================
# APPLICATION CONFIGURATION
# ==============================================================================

# Public URL where the app is hosted
# Development: http://localhost:3000
# Production: https://your-domain.com (Vercel auto-sets this as VERCEL_URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ==============================================================================
# EVOLUTION API (WHATSAPP) - NOT NEEDED HERE
# ==============================================================================
# Evolution API configuration is done PER TENANT in the system settings.
# Each user configures their own Evolution API URL and Global API Key
# through the admin interface at: /admin/settings or /settings
#
# The values are stored in the database (tenants.settings or system_settings)
# and retrieved at runtime when making WhatsApp API calls.
#
# This allows each tenant to use their own Evolution API instance.
# ==============================================================================


# ==============================================================================
# ENCRYPTION KEY
# ==============================================================================
# Used to encrypt sensitive data like WhatsApp instance API keys stored in database.
# Generate a secure 32-byte (64 hex characters) key:
#   Node.js: require('crypto').randomBytes(32).toString('hex')
#   OpenSSL: openssl rand -hex 32
#
# IMPORTANT:
# - Keep this key secure and backed up
# - If you lose this key, encrypted data cannot be recovered
# - Use the same key in Modal worker secrets
ENCRYPTION_KEY=your-64-character-hex-key


# ==============================================================================
# MODAL WORKER CONFIGURATION (Campaign Processing)
# ==============================================================================
# Modal.com is used for long-running background jobs (campaign sending).
# Create an account at https://modal.com and set up your workspace.
#
# Note: These are only needed if you want to use Modal for campaign processing.
# If not configured, campaigns will use the fallback in-process sender.

# Modal API endpoint (usually https://api.modal.com)
# MODAL_API_URL=https://api.modal.com

# Modal authentication tokens
# Get from: Modal Dashboard > Settings > API Tokens
# Create a new token with appropriate permissions
# MODAL_TOKEN_ID=your-modal-token-id
# MODAL_TOKEN_SECRET=your-modal-token-secret

# Name of the deployed Modal function for campaigns
# This should match the function name in modal/campaign_worker.py
# MODAL_FUNCTION_NAME=campaign-worker


# ==============================================================================
# WEBHOOK SECRETS
# ==============================================================================
# Secrets used to authenticate webhook callbacks from external services.

# Secret for Modal webhook callbacks
# Generate a secure random string:
#   Node.js: require('crypto').randomBytes(32).toString('hex')
#   OpenSSL: openssl rand -hex 32
#
# Must be configured in Modal secrets as SCALECORE_WEBHOOK_SECRET
SCALECORE_WEBHOOK_SECRET=your-webhook-secret

# Salt for generating webhook secrets per instance (optional, legacy)
# Used by the WhatsApp webhook to verify authenticity
WEBHOOK_SECRET_SALT=generate-a-random-string-here


# ==============================================================================
# CRON SECRET (Warming System)
# ==============================================================================
# Secret used to authenticate the cron job that processes warming sessions.
# The warming system uses Supabase pg_cron to call /api/warming/execute every minute.
#
# Generate a secure random string:
#   Node.js: require('crypto').randomBytes(32).toString('hex')
#   OpenSSL: openssl rand -hex 32
#
# IMPORTANT: This same value must be configured in Supabase:
#   ALTER DATABASE postgres SET app.settings.cron_secret = 'your-secret';
#
# If not set, the warming execute endpoint will accept authenticated user calls
# but won't work with the pg_cron automated calls.
CRON_SECRET=your-cron-secret


# ==============================================================================
# ANTHROPIC API (AI Message Generation - Optional)
# ==============================================================================
# Used for AI-powered message generation in the warming system.
# The warming system can generate natural conversations using Claude Haiku.
#
# Get your API key from: https://console.anthropic.com/
#
# If not configured, the warming system will use template-based messages only.
# Cost: ~$0.25/1M input tokens, $1.25/1M output tokens (approximately R$0.01 per 100 messages)
#
# ANTHROPIC_API_KEY=sk-ant-your-api-key


# ==============================================================================
# SUPER ADMIN CONFIGURATION
# ==============================================================================
# Email address for the initial super admin user.
# This user will have access to the /admin panel.
# Only the first user with this email gets super admin privileges.
SUPER_ADMIN_EMAIL=admin@your-domain.com


# ==============================================================================
# MODAL WORKER SECRETS (Configure in Modal Dashboard)
# ==============================================================================
# The following secrets need to be configured in Modal Dashboard:
# Modal Dashboard > Secrets > Create new secret
#
# Required secrets for the campaign-worker:
#
# SUPABASE_URL           - Same as NEXT_PUBLIC_SUPABASE_URL
# SUPABASE_SERVICE_KEY   - Same as SUPABASE_SERVICE_ROLE_KEY
# ENCRYPTION_KEY         - Same as ENCRYPTION_KEY above
# SCALECORE_WEBHOOK_URL  - Your app's webhook endpoint:
#                          https://your-domain.com/api/webhooks/modal
# SCALECORE_WEBHOOK_SECRET - Same as SCALECORE_WEBHOOK_SECRET above
#
# ==============================================================================


# ==============================================================================
# VERCEL DEPLOYMENT (Auto-configured by Vercel)
# ==============================================================================
# These variables are automatically set by Vercel during deployment.
# You don't need to configure them manually.
#
# VERCEL_URL          - Deployment URL (auto-set)
# VERCEL_ENV          - Environment: production, preview, or development
# VERCEL_GIT_COMMIT_SHA - Git commit SHA
#
# For Vercel deployment, add all required environment variables in:
# Vercel Dashboard > Project > Settings > Environment Variables
#
# Required variables for Vercel:
# - NEXT_PUBLIC_SUPABASE_URL
# - NEXT_PUBLIC_SUPABASE_ANON_KEY
# - SUPABASE_SERVICE_ROLE_KEY
# - NEXT_PUBLIC_APP_URL (set to your production domain)
# - ENCRYPTION_KEY
# - SCALECORE_WEBHOOK_SECRET
# - CRON_SECRET
# - SUPER_ADMIN_EMAIL
#
# Optional (if using Modal):
# - MODAL_API_URL
# - MODAL_TOKEN_ID
# - MODAL_TOKEN_SECRET
# - MODAL_FUNCTION_NAME
# ==============================================================================
